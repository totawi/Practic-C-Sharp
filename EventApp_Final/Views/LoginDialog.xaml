<Window x:Class="EventApp.Views.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="420" Width="400"
        MinHeight="400" MinWidth="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F7FA">
    <Window.Resources>
        <ControlTemplate x:Key="BtnTpl" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}" Cursor="Hand">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Margin="28,20,28,28">
            <StackPanel>
                <!-- Заголовок -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <TextBlock Text="🔐 " FontSize="24" VerticalAlignment="Center"/>
                    <TextBlock Text="Вход в EventApp"
                               FontFamily="Segoe UI" FontSize="20" FontWeight="SemiBold"
                               Foreground="#1A202C" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="Логин" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#4A5568" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtUsername" FontFamily="Segoe UI" FontSize="14"
                         Padding="10,9" BorderBrush="#CBD5E0" Margin="0,0,0,14"/>

                <TextBlock Text="Пароль" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#4A5568" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtPassword" FontFamily="Segoe UI" FontSize="14"
                             Padding="10,9" BorderBrush="#CBD5E0" Margin="0,0,0,10"/>

                <TextBlock x:Name="TxtError" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#E53E3E" Margin="0,0,0,10" TextWrapping="Wrap"/>

                <Border Background="#EBF8FF" CornerRadius="6" Padding="12,8" Margin="0,0,0,20">
                    <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#2B6CB0"
                               TextAlignment="Center">
                        <Run Text="Демо: "/>
                        <Run Text="admin / admin123" FontWeight="Bold"/>
                        <Run Text="  или  "/>
                        <Run Text="user1 / user123" FontWeight="Bold"/>
                    </TextBlock>
                </Border>

                <!-- Кнопки: Войти и Регистрация — по всей ширине, стопкой -->
                <Button Content="Войти"
                        Template="{StaticResource BtnTpl}"
                        Background="#2B6CB0" Foreground="White"
                        FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                        Padding="0,11" BorderThickness="0" Margin="0,0,0,8"
                        Click="BtnLogin_Click"/>

                <Button Content="Зарегистрироваться"
                        Template="{StaticResource BtnTpl}"
                        Background="#276749" Foreground="White"
                        FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                        Padding="0,11" BorderThickness="0" Margin="0,0,0,8"
                        Click="BtnRegister_Click"/>

                <Button Content="Отмена"
                        Template="{StaticResource BtnTpl}"
                        Background="#EDF2F7" Foreground="#4A5568"
                        FontFamily="Segoe UI" FontSize="13"
                        Padding="0,9" BorderThickness="0"
                        Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>
