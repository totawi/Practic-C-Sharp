<Window x:Class="EventApp.Views.RegisterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="400" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F7FA">
    <Window.Resources>
        <ControlTemplate x:Key="BtnTpl" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}" Cursor="Hand">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Resources>

    <Border Margin="24">
        <StackPanel>
            <TextBlock Text="Регистрация нового пользователя"
                       FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                       Foreground="#1A202C" Margin="0,0,0,16" HorizontalAlignment="Center"/>

            <Label Content="Логин *"/>
            <TextBox x:Name="TxtUsername"/>

            <Label Content="Пароль *"/>
            <PasswordBox x:Name="TxtPassword" FontFamily="Segoe UI" FontSize="13"
                         Padding="8,6" BorderBrush="#CBD5E0" Margin="0,0,0,10"/>

            <Label Content="Отображаемое имя *"/>
            <TextBox x:Name="TxtDisplay"/>

            <Label Content="Email"/>
            <TextBox x:Name="TxtEmail"/>

            <CheckBox x:Name="ChkOrganizer" Content="Роль: Организатор"
                      FontFamily="Segoe UI" FontSize="12"
                      Foreground="#4A5568" Margin="0,0,0,12"/>

            <TextBlock x:Name="TxtError" FontFamily="Segoe UI" FontSize="12"
                       Foreground="#E53E3E" Margin="0,0,0,12" TextWrapping="Wrap"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Зарегистрироваться"
                        Template="{StaticResource BtnTpl}"
                        Background="#276749" Foreground="White"
                        FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="0,9" BorderThickness="0"
                        Click="BtnRegister_Click"/>
                <Button Grid.Column="2" Content="Отмена"
                        Template="{StaticResource BtnTpl}"
                        Background="#EDF2F7" Foreground="#4A5568"
                        FontFamily="Segoe UI" FontSize="13"
                        Padding="0,9" BorderThickness="0"
                        Click="BtnCancel_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
