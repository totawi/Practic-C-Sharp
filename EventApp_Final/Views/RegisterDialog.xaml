<Window x:Class="EventApp.Views.RegisterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="430" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinHeight="400"
        Background="#F8FAFC">
    <Window.Resources>
        <ControlTemplate x:Key="BtnTpl" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}" Cursor="Hand">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Margin="26,20,26,26">
            <StackPanel>

                <TextBlock Text="Регистрация"
                           FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold"
                           Foreground="#111827" HorizontalAlignment="Center"
                           Margin="0,0,0,18"/>

                <TextBlock Text="Логин *" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#374151" Margin="0,0,0,3"/>
                <TextBox x:Name="TxtUsername" FontFamily="Segoe UI" FontSize="13"
                         Padding="9,7" BorderBrush="#CBD5E1" Margin="0,0,0,10"/>

                <TextBlock Text="Пароль * (минимум 3 символа)" FontFamily="Segoe UI"
                           FontSize="12" Foreground="#374151" Margin="0,0,0,3"/>
                <PasswordBox x:Name="TxtPassword" FontFamily="Segoe UI" FontSize="13"
                             Padding="9,7" BorderBrush="#CBD5E1" Margin="0,0,0,10"/>

                <TextBlock Text="Имя (как отображается) *" FontFamily="Segoe UI"
                           FontSize="12" Foreground="#374151" Margin="0,0,0,3"/>
                <TextBox x:Name="TxtDisplay" FontFamily="Segoe UI" FontSize="13"
                         Padding="9,7" BorderBrush="#CBD5E1" Margin="0,0,0,10"/>

                <TextBlock Text="Email" FontFamily="Segoe UI" FontSize="12"
                           Foreground="#374151" Margin="0,0,0,3"/>
                <TextBox x:Name="TxtEmail" FontFamily="Segoe UI" FontSize="13"
                         Padding="9,7" BorderBrush="#CBD5E1" Margin="0,0,0,12"/>

                <CheckBox x:Name="ChkOrganizer"
                          Content="Организатор (может создавать мероприятия)"
                          FontFamily="Segoe UI" FontSize="12"
                          Foreground="#374151" Margin="0,0,0,14"/>

                <!-- Ошибка -->
                <TextBlock x:Name="TxtError"
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="#DC2626" TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <Button x:Name="BtnRegisterBtn"
                        Content="Зарегистрироваться"
                        Template="{StaticResource BtnTpl}"
                        Background="#1E40AF" Foreground="White"
                        FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="0,11" BorderThickness="0" Margin="0,0,0,8"
                        Click="BtnRegister_Click"/>

                <Button Content="Отмена"
                        Template="{StaticResource BtnTpl}"
                        Background="#F1F5F9" Foreground="#374151"
                        FontFamily="Segoe UI" FontSize="13"
                        Padding="0,10" BorderThickness="0"
                        Click="BtnCancel_Click"/>

            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>
