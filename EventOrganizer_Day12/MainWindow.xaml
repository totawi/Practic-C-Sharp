<Window x:Class="EventOrganizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Организация мероприятий"
        Height="680" Width="1100"
        MinHeight="600" MinWidth="900"
        Background="#F4F6F9"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Стиль заголовочной панели -->
        <Style x:Key="HeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A237E"/>
            <Setter Property="Padding" Value="20,14"/>
        </Style>

        <!-- Стиль кнопки основной -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1A237E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#283593"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D1461"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки вторичной -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E8EAF6"/>
            <Setter Property="Foreground" Value="#1A237E"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C5CAE9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки опасной -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#FFEBEE"/>
            <Setter Property="Foreground" Value="#C62828"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFCDD2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль карточки-панели -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="12" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#C5CAE9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#1A237E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="#C5CAE9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- Стиль DatePicker -->
        <Style TargetType="DatePicker">
            <Setter Property="BorderBrush" Value="#C5CAE9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- Метка формы -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#5C6BC0"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Style="{StaticResource HeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📋" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Организация мероприятий"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Управление событиями и участниками"
                                   FontSize="12" Foreground="#9FA8DA"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <Border Background="#283593" CornerRadius="20" Padding="10,4" Margin="0,0,8,0">
                        <TextBlock x:Name="TotalEventsLabel" Text="Мероприятий: 0"
                                   FontSize="12" Foreground="#C5CAE9"/>
                    </Border>
                    <Border Background="#283593" CornerRadius="20" Padding="10,4">
                        <TextBlock x:Name="TotalParticipantsLabel" Text="Участников: 0"
                                   FontSize="12" Foreground="#C5CAE9"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="340"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка: список мероприятий -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Панель управления мероприятиями -->
                <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Новое мероприятие"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#1A237E" Margin="0,0,0,12"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="НАЗВАНИЕ" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
                                <TextBox x:Name="EventNameBox"
                                         Tag="Название мероприятия..."
                                         GotFocus="TextBox_GotFocus"
                                         LostFocus="TextBox_LostFocus"
                                         Foreground="#9E9E9E"
                                         Text="Название мероприятия..."/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ДАТА" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
                                <DatePicker x:Name="EventDatePicker" SelectedDate="{x:Static sys:DateTime.Today}"
                                            xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="СЕКЦИЯ" Style="{StaticResource FormLabel}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="EventSectionBox">
                                    <ComboBoxItem Content="Пленарная" IsSelected="True"/>
                                    <ComboBoxItem Content="Техническая"/>
                                    <ComboBoxItem Content="Научная"/>
                                    <ComboBoxItem Content="Мастер-класс"/>
                                    <ComboBoxItem Content="Воркшоп"/>
                                    <ComboBoxItem Content="Другое"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                                <Button Content="+ Добавить" Style="{StaticResource PrimaryButton}"
                                        Click="AddEvent_Click" Height="32"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- DataGrid мероприятий -->
                <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Список мероприятий"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="#1A237E" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Удалить выбранное"
                                    Style="{StaticResource DangerButton}"
                                    Click="DeleteEvent_Click" Height="28" FontSize="12"/>
                        </Grid>

                        <DataGrid x:Name="EventsDataGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#E8EAF6"
                                  BorderThickness="0"
                                  RowBackground="White"
                                  AlternatingRowBackground="#FAFAFA"
                                  FontSize="13"
                                  ColumnHeaderHeight="36"
                                  RowHeight="36"
                                  SelectionChanged="EventsDataGrid_SelectionChanged">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#E8EAF6"/>
                                    <Setter Property="Foreground" Value="#3949AB"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="40" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Название мероприятия" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding DateFormatted}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Секция" Binding="{Binding Section}" Width="110" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Участников" Binding="{Binding ParticipantCount}" Width="90" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Участники выбранного мероприятия -->
                <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,12,0,0" MinHeight="150">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="ParticipantsOfEventLabel"
                                   Text="Участники мероприятия"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#1A237E" Margin="0,0,0,10"/>

                        <ListBox x:Name="EventParticipantsListBox"
                                 Grid.Row="1"
                                 BorderThickness="1"
                                 BorderBrush="#E8EAF6"
                                 MinHeight="100" MaxHeight="140"
                                 FontSize="13"
                                 Background="#FAFAFA"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                        <Border Background="#E8EAF6" CornerRadius="10" Padding="6,2" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Initials}" FontSize="11"
                                                       Foreground="#3949AB" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Text="{Binding FullName}" VerticalAlignment="Center"/>
                                        <TextBlock Text=" — " Foreground="#9E9E9E" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Role}" Foreground="#5C6BC0"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- Правая колонка: регистрация участников -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Форма регистрации -->
                <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Регистрация участника"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#1A237E" Margin="0,0,0,4"/>
                        <TextBlock Text="Заполните данные и выберите мероприятие"
                                   FontSize="11" Foreground="#9E9E9E" Margin="0,0,0,8"/>

                        <TextBlock Text="ИМЯ" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="ParticipantFirstNameBox"
                                 Tag="Введите имя..."
                                 GotFocus="TextBox_GotFocus"
                                 LostFocus="TextBox_LostFocus"
                                 Foreground="#9E9E9E"
                                 Text="Введите имя..."/>

                        <TextBlock Text="ФАМИЛИЯ" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="ParticipantLastNameBox"
                                 Tag="Введите фамилию..."
                                 GotFocus="TextBox_GotFocus"
                                 LostFocus="TextBox_LostFocus"
                                 Foreground="#9E9E9E"
                                 Text="Введите фамилию..."/>

                        <TextBlock Text="E-MAIL" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="ParticipantEmailBox"
                                 Tag="example@mail.com"
                                 GotFocus="TextBox_GotFocus"
                                 LostFocus="TextBox_LostFocus"
                                 Foreground="#9E9E9E"
                                 Text="example@mail.com"/>

                        <TextBlock Text="РОЛЬ / ДОЛЖНОСТЬ" Style="{StaticResource FormLabel}"/>
                        <ComboBox x:Name="ParticipantRoleBox">
                            <ComboBoxItem Content="Докладчик" IsSelected="True"/>
                            <ComboBoxItem Content="Слушатель"/>
                            <ComboBoxItem Content="Организатор"/>
                            <ComboBoxItem Content="Модератор"/>
                            <ComboBoxItem Content="Гость"/>
                            <ComboBoxItem Content="Спонсор"/>
                        </ComboBox>

                        <TextBlock Text="МЕРОПРИЯТИЕ" Style="{StaticResource FormLabel}"/>
                        <ComboBox x:Name="ParticipantEventBox"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"/>

                        <Button Content="✓ Зарегистрировать участника"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,14,0,0"
                                Click="RegisterParticipant_Click"/>
                    </StackPanel>
                </Border>

                <!-- Все участники ListBox -->
                <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Все участники"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#1A237E"/>
                                <TextBlock x:Name="AllParticipantsCountLabel"
                                           Text="0 зарегистрировано"
                                           FontSize="11" Foreground="#9E9E9E"/>
                            </StackPanel>
                        </Grid>

                        <ListBox x:Name="AllParticipantsListBox"
                                 Grid.Row="1"
                                 BorderThickness="1"
                                 BorderBrush="#E8EAF6"
                                 Background="#FAFAFA"
                                 FontSize="12"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,3" Width="260">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#3949AB" CornerRadius="14"
                                                Width="28" Height="28" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Initials}"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}"
                                                       FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock FontSize="11" Foreground="#9E9E9E">
                                                <Run Text="{Binding Role}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding EventName}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Grid.Row="2"
                                Content="Удалить участника"
                                Style="{StaticResource DangerButton}"
                                Margin="0,8,0,0"
                                Click="DeleteParticipant_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Статус-бар -->
        <Border Grid.Row="2" Background="#1A237E" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel"
                           Text="Готово. Добавьте мероприятие для начала работы."
                           FontSize="12" Foreground="#9FA8DA" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="EventOrganizer v1.0 · Практическое задание"
                           FontSize="11" Foreground="#5C6BC0" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
