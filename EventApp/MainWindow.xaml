<Window x:Class="EventApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EventApp.ViewModels"
        xmlns:conv="clr-namespace:EventApp.Converters"
        Title="Организация мероприятий" Height="680" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>

        <!-- Converters -->
        <conv:BoolToVisibilityConverter  x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter  x:Key="NullToVis"/>
        <conv:CountToStringConverter     x:Key="CountToStr"/>

        <!-- Общая тень для карточек -->
        <DropShadowEffect x:Key="CardShadow"
                          Color="#CBD5E0" BlurRadius="12" ShadowDepth="2" Opacity="0.4"/>

        <!-- ControlTemplate: кнопка «Зарегистрировать» с иконкой человека -->
        <ControlTemplate x:Key="RegisterButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="#276749" CornerRadius="6"
                    Padding="12,7" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="16" Height="16" Margin="0,0,7,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White"
                                  Data="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4
                                        7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6
                                        1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                        </Canvas>
                    </Viewbox>
                    <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True"/>
                </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#22543D"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#1C4532"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Background" Value="#A0AEC0"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ControlTemplate: кнопки панели инструментов -->
        <ControlTemplate x:Key="ToolbarBtnTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="5" Padding="10,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{TemplateBinding Tag}" FontSize="14"
                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <ContentPresenter VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#E2E8F0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#CBD5E0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ControlTemplate: маленькая кнопка (для карточки) -->
        <ControlTemplate x:Key="SmallBtnTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="5" Padding="{TemplateBinding Padding}" Cursor="Hand">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ControlTemplate: кнопка «Создать» в заголовке левой панели -->
        <ControlTemplate x:Key="CreateBtnTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="#2B6CB0" CornerRadius="5"
                    Padding="{TemplateBinding Padding}" Cursor="Hand">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#2C5282"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- DataTemplate: карточка мероприятия в ListBox -->
        <DataTemplate x:Key="EventItemTemplate">
            <Border x:Name="ItemBorder" Background="White"
                    BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Name}"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#1A202C" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock Text="📅 " FontSize="11"/>
                            <TextBlock Text="{Binding DateDisplay}"
                                       FontFamily="Segoe UI" FontSize="11" Foreground="#718096"/>
                            <TextBlock Text="  •  📍 " FontSize="11" Foreground="#A0AEC0"/>
                            <TextBlock Text="{Binding Location}"
                                       FontFamily="Segoe UI" FontSize="11" Foreground="#718096"
                                       TextTrimming="CharacterEllipsis" MaxWidth="110"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- OneWay: счётчик участников -->
                    <Border Grid.Column="1" CornerRadius="10" Padding="8,3"
                            Background="#EBF4FF" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥 " FontSize="10"/>
                            <TextBlock Text="{Binding ParticipantCount, Mode=OneWay}"
                                       FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                                       Foreground="#2B6CB0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected,
                    RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="#EBF4FF"/>
                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#BEE3F8"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- DataTemplate: строка участника -->
        <DataTemplate x:Key="ParticipantItemTemplate">
            <Border x:Name="PBorder" Background="Transparent"
                    BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Аватар -->
                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                            Background="#2B6CB0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LastName[0]}"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FullName}"
                                   FontFamily="Segoe UI" FontSize="13" Foreground="#1A202C"/>
                        <TextBlock Text="{Binding Email}"
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#718096"/>
                    </StackPanel>
                    <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                            Background="#F0FFF4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Section}"
                                   FontFamily="Segoe UI" FontSize="10" Foreground="#276749"/>
                    </Border>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected,
                    RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="PBorder" Property="Background" Value="#EBF8FF"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Style: ListBox без стандартного выделения -->
        <Style x:Key="CleanListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- Style: ListBoxItem без highlight -->
        <Style x:Key="CleanItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Горячие клавиши -->
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding CreateEventCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditEventCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteEventCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ГЛАВНОЕ МЕНЮ -->
        <Menu DockPanel.Dock="Top" Background="#2D3748" FontFamily="Segoe UI" FontSize="13">
            <Menu.ItemContainerStyle>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="#4A5568"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Menu.ItemContainerStyle>
            <MenuItem Header="_Файл">
                <MenuItem Header="Новое мероприятие (Ctrl+N)" Command="{Binding CreateEventCommand}"/>
                <Separator/>
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Мероприятия">
                <MenuItem Header="Создать (Ctrl+N)"       Command="{Binding CreateEventCommand}"/>
                <MenuItem Header="Редактировать (Ctrl+E)" Command="{Binding EditEventCommand}"/>
                <MenuItem Header="Удалить (Ctrl+D)"       Command="{Binding DeleteEventCommand}"/>
            </MenuItem>
            <MenuItem Header="_Участники">
                <MenuItem Header="Зарегистрировать"  Command="{Binding AddParticipantCommand}"/>
                <MenuItem Header="Редактировать"      Command="{Binding EditParticipantCommand}"/>
                <MenuItem Header="Удалить участника"  Command="{Binding DeleteParticipantCommand}"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="Параметры…" IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="_Помощь">
                <MenuItem Header="О программе" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ПАНЕЛЬ ИНСТРУМЕНТОВ -->
        <Border DockPanel.Dock="Top" Background="#F7FAFC"
                BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Tag="➕" Content="Создать мероприятие"
                        Template="{StaticResource ToolbarBtnTemplate}"
                        Command="{Binding CreateEventCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#2D3748"
                        Background="Transparent" BorderThickness="0"
                        ToolTip="Создать мероприятие (Ctrl+N)"/>
                <Rectangle Width="1" Fill="#CBD5E0" Margin="6,4"/>
                <Button Tag="✏️" Content="Редактировать"
                        Template="{StaticResource ToolbarBtnTemplate}"
                        Command="{Binding EditEventCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#2D3748"
                        Background="Transparent" BorderThickness="0"
                        ToolTip="Редактировать (Ctrl+E)"/>
                <Button Tag="🗑️" Content="Удалить"
                        Template="{StaticResource ToolbarBtnTemplate}"
                        Command="{Binding DeleteEventCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#C53030"
                        Background="Transparent" BorderThickness="0"
                        ToolTip="Удалить (Ctrl+D)"/>
                <Rectangle Width="1" Fill="#CBD5E0" Margin="6,4"/>
                <Button Tag="👤" Content="Добавить участника"
                        Template="{StaticResource ToolbarBtnTemplate}"
                        Command="{Binding AddParticipantCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#276749"
                        Background="Transparent" BorderThickness="0"
                        ToolTip="Зарегистрировать участника"/>
            </StackPanel>
        </Border>

        <!-- ЗАГОЛОВОК -->
        <Border DockPanel.Dock="Top" Background="#2B6CB0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Организация мероприятий"
                               FontFamily="Segoe UI" FontSize="22" FontWeight="Light"
                               Foreground="White"/>
                    <TextBlock Text="Управление мероприятиями и участниками"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#BEE3F8" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" CornerRadius="8" Background="#2C5282" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋 " FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#90CDF4"
                                   VerticalAlignment="Center">
                            <Run Text="Всего мероприятий: "/>
                            <Run Text="{Binding Events.Count, Mode=OneWay}"
                                 FontWeight="Bold" Foreground="White"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- РАБОЧАЯ ОБЛАСТЬ -->
        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="250"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ПАНЕЛЬ: список мероприятий -->
            <Border Grid.Column="0" Background="White" CornerRadius="10"
                    Effect="{StaticResource CardShadow}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#EBF4FF"
                            CornerRadius="10,10,0,0" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Мероприятия"
                                       FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#2B6CB0" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="+ Создать"
                                    Command="{Binding CreateEventCommand}"
                                    Template="{StaticResource CreateBtnTemplate}"
                                    FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                    Foreground="White" Padding="10,4" BorderThickness="0"/>
                        </Grid>
                    </Border>
                    <ListBox Style="{StaticResource CleanListBoxStyle}"
                             ItemContainerStyle="{StaticResource CleanItemStyle}"
                             ItemsSource="{Binding Events}"
                             SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                             ItemTemplate="{StaticResource EventItemTemplate}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Border>

            <!-- Сплиттер -->
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- ПРАВАЯ ПАНЕЛЬ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заглушка «ничего не выбрано» (видна когда SelectedEvent == null) -->
                <Border Grid.Row="0" Grid.RowSpan="3"
                        Background="White" CornerRadius="10"
                        Effect="{StaticResource CardShadow}"
                        Visibility="{Binding SelectedEvent,
                            Converter={StaticResource NullToVis},
                            ConverterParameter=Invert}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="Выберите мероприятие из списка" Margin="0,12,0,0"
                                   FontFamily="Segoe UI" FontSize="15" Foreground="#A0AEC0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="или создайте новое (Ctrl+N)" Margin="0,4,0,0"
                                   FontFamily="Segoe UI" FontSize="12" Foreground="#CBD5E0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Карточка мероприятия -->
                <Border Grid.Row="0" Background="White" CornerRadius="10"
                        Effect="{StaticResource CardShadow}"
                        Visibility="{Binding SelectedEvent, Converter={StaticResource NullToVis}}">
                    <Grid Margin="20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <!-- TwoWay: название -->
                            <TextBox Text="{Binding SelectedEvent.Name,
                                         Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Segoe UI" FontSize="20" FontWeight="SemiBold"
                                     Foreground="#1A202C" BorderThickness="0"
                                     Background="Transparent" Padding="0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="📅 " FontSize="12" VerticalAlignment="Center"/>
                                <!-- TwoWay: дата -->
                                <DatePicker SelectedDate="{Binding SelectedEvent.Date, Mode=TwoWay}"
                                            FontFamily="Segoe UI" FontSize="12"
                                            BorderThickness="0" Background="Transparent"
                                            Margin="0,-3,0,0" VerticalAlignment="Center"/>
                                <TextBlock Text="  📍 " FontSize="12" Foreground="#A0AEC0"
                                           VerticalAlignment="Center"/>
                                <!-- TwoWay: место -->
                                <TextBox Text="{Binding SelectedEvent.Location,
                                             Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Segoe UI" FontSize="12" Foreground="#718096"
                                         BorderThickness="0" Background="Transparent" Padding="0"
                                         VerticalAlignment="Center" MinWidth="100"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- OneWay: счётчик -->
                            <Border CornerRadius="8" Background="#EBF4FF"
                                    Padding="12,6" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedEvent.ParticipantCount, Mode=OneWay}"
                                               FontFamily="Segoe UI" FontSize="24" FontWeight="Bold"
                                               Foreground="#2B6CB0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedEvent.ParticipantCount,
                                                   Mode=OneWay, Converter={StaticResource CountToStr}}"
                                               FontFamily="Segoe UI" FontSize="10" Foreground="#718096"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <StackPanel>
                                <Button Content="✏️ Редактировать"
                                        Command="{Binding EditEventCommand}"
                                        Template="{StaticResource SmallBtnTemplate}"
                                        FontFamily="Segoe UI" FontSize="12"
                                        Padding="10,6" Margin="0,0,0,4"
                                        Background="#EDF2F7" Foreground="#2D3748"
                                        BorderThickness="0"/>
                                <Button Content="🗑️ Удалить"
                                        Command="{Binding DeleteEventCommand}"
                                        Template="{StaticResource SmallBtnTemplate}"
                                        FontFamily="Segoe UI" FontSize="12"
                                        Padding="10,6" Background="#FFF5F5"
                                        Foreground="#C53030" BorderThickness="0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Панель участников -->
                <Border Grid.Row="2" Background="White" CornerRadius="10"
                        Effect="{StaticResource CardShadow}"
                        Visibility="{Binding SelectedEvent, Converter={StaticResource NullToVis}}">
                    <DockPanel>
                        <!-- Заголовок панели участников -->
                        <Border DockPanel.Dock="Top" Background="#F0FFF4"
                                CornerRadius="10,10,0,0" Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Регистрация участников"
                                               FontFamily="Segoe UI" FontSize="14"
                                               FontWeight="SemiBold" Foreground="#276749"
                                               VerticalAlignment="Center"/>
                                    <!-- OneWay: счётчик в заголовке -->
                                    <Border CornerRadius="10" Background="#276749"
                                            Padding="8,2" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding SelectedEvent.ParticipantCount, Mode=OneWay}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <!-- Кнопка с ControlTemplate (иконка человека) -->
                                    <Button Content="Зарегистрировать"
                                            Template="{StaticResource RegisterButtonTemplate}"
                                            Command="{Binding AddParticipantCommand}"
                                            FontFamily="Segoe UI" FontSize="12"
                                            FontWeight="SemiBold" Foreground="White"
                                            BorderThickness="0" Margin="0,0,8,0"
                                            ToolTip="Добавить участника"/>
                                    <Button Content="✏️"
                                            Command="{Binding EditParticipantCommand}"
                                            Template="{StaticResource SmallBtnTemplate}"
                                            FontFamily="Segoe UI" FontSize="13"
                                            Padding="8,5" Background="#EDF2F7"
                                            Foreground="#2D3748" BorderThickness="0"
                                            ToolTip="Редактировать участника"
                                            Margin="0,0,6,0"/>
                                    <Button Content="🗑️"
                                            Command="{Binding DeleteParticipantCommand}"
                                            Template="{StaticResource SmallBtnTemplate}"
                                            FontFamily="Segoe UI" FontSize="13"
                                            Padding="8,5" Background="#FFF5F5"
                                            Foreground="#C53030" BorderThickness="0"
                                            ToolTip="Удалить участника"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ListBox участников -->
                        <ListBox ItemsSource="{Binding CurrentParticipants}"
                                 SelectedItem="{Binding SelectedParticipant, Mode=TwoWay}"
                                 ItemTemplate="{StaticResource ParticipantItemTemplate}"
                                 ItemContainerStyle="{StaticResource CleanItemStyle}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentParticipants.Count}"
                                                     Value="0">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate>
                                                        <StackPanel HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,30">
                                                            <TextBlock Text="👥" FontSize="36"
                                                                       HorizontalAlignment="Center"/>
                                                            <TextBlock Text="Участников пока нет"
                                                                       FontFamily="Segoe UI" FontSize="14"
                                                                       Foreground="#A0AEC0"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,10,0,0"/>
                                                            <TextBlock Text="Нажмите «Зарегистрировать»"
                                                                       FontFamily="Segoe UI" FontSize="12"
                                                                       Foreground="#CBD5E0"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
