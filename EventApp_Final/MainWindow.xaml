<Window x:Class="EventApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:EventApp.Converters"
        Title="EventApp — Организация мероприятий" Height="760" Width="1240"
        MinHeight="620" MinWidth="940"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9"
        Closing="Window_Closing">

    <Window.Resources>
        <conv:BoolToVisibilityConverter  x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter  x:Key="NullToVis"/>
        <conv:CountToStringConverter     x:Key="CountToStr"/>
        <conv:InverseBoolToVisConverter  x:Key="InvBoolToVis"/>

        <DropShadowEffect x:Key="CardShadow" Color="#94A3B8"
                          BlurRadius="12" ShadowDepth="2" Opacity="0.25"/>

        <!-- Анимации появления блоков -->
        <Style x:Key="AnimCard" TargetType="Border">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform"><Setter.Value><TranslateTransform Y="20"/></Setter.Value></Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.45">
                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.45">
                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AnimCard1" TargetType="Border" BasedOn="{StaticResource AnimCard}">
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard BeginTime="0:0:0.1">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.45"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.45"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AnimCard2" TargetType="Border" BasedOn="{StaticResource AnimCard}">
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard BeginTime="0:0:0.2">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.45"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.45"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AnimCard3" TargetType="Border" BasedOn="{StaticResource AnimCard}">
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard BeginTime="0:0:0.3">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.45"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.45"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- ControlTemplate: кнопка «Зарегистрироваться» с иконкой -->
        <ControlTemplate x:Key="RegisterBtnTpl" TargetType="Button">
            <Border x:Name="Bd" Background="#16A34A" CornerRadius="7" Padding="12,8" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="15" Height="15" Margin="0,0,6,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White" Data="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                        </Canvas>
                    </Viewbox>
                    <ContentPresenter VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#15803D"/></Trigger>
                <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Background" Value="#CBD5E1"/></Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Обычная кнопка тулбара -->
        <ControlTemplate x:Key="ToolbarBtnTpl" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="10,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{TemplateBinding Tag}" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <ContentPresenter VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#E2E8F0"/></Trigger>
                <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.4"/></Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Маленькая кнопка -->
        <ControlTemplate x:Key="SmallBtnTpl" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                    Padding="{TemplateBinding Padding}" Cursor="Hand">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.4"/></Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- DataTemplate: строка ListView мероприятий -->
        <DataTemplate x:Key="EventListItemTpl">
            <Border x:Name="Bd" Background="White" BorderThickness="0,0,0,1"
                    BorderBrush="#E2E8F0" Padding="14,11" Cursor="Hand">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}" FontFamily="Segoe UI" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#1E293B"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock Text="📅 " FontSize="11"/>
                            <TextBlock Text="{Binding DateDisplay}" FontFamily="Segoe UI"
                                       FontSize="11" Foreground="#64748B"/>
                            <TextBlock Text="  •  📍 " FontSize="11" Foreground="#94A3B8"/>
                            <TextBlock Text="{Binding Location}" FontFamily="Segoe UI"
                                       FontSize="11" Foreground="#64748B"
                                       TextTrimming="CharacterEllipsis" MaxWidth="100"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="10" Padding="9,3"
                            Background="#DBEAFE" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ParticipantCount, Mode=OneWay}"
                                   FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"
                                   Foreground="#1E3A8A"/>
                    </Border>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                    <Setter TargetName="Bd" Property="BorderBrush" Value="#BFDBFE"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#F8FAFC"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- DataTemplate: участник в ListBox -->
        <DataTemplate x:Key="ParticipantItemTpl">
            <Border x:Name="Bd" Background="Transparent" BorderThickness="0,0,0,1"
                    BorderBrush="#F1F5F9" Padding="12,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="14" Background="#2563EB">
                        <TextBlock Text="{Binding LastName[0]}" FontFamily="Segoe UI"
                                   FontSize="12" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FullName}" FontFamily="Segoe UI"
                                   FontSize="13" Foreground="#1E293B"/>
                        <TextBlock Text="{Binding Email}" FontFamily="Segoe UI"
                                   FontSize="11" Foreground="#94A3B8"/>
                    </StackPanel>
                    <Border Grid.Column="2" CornerRadius="5" Padding="7,3"
                            Background="#D1FAE5" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Section}" FontFamily="Segoe UI"
                                   FontSize="10" Foreground="#065F46"/>
                    </Border>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="LvItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value><ControlTemplate TargetType="ListViewItem"><ContentPresenter/></ControlTemplate></Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LbItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value><ControlTemplate TargetType="ListBoxItem"><ContentPresenter/></ControlTemplate></Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding CreateEventCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditEventCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteEventCommand}"/>
        <KeyBinding Key="I" Modifiers="Ctrl" Command="{Binding ShowEventDetailCommand}"/>
        <KeyBinding Key="L" Modifiers="Ctrl" Command="{Binding LoginCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ══ МЕНЮ ══ -->
        <Menu DockPanel.Dock="Top" Background="#1E40AF" FontFamily="Segoe UI" FontSize="13">
            <Menu.ItemContainerStyle>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="#1D4ED8"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Menu.ItemContainerStyle>
            <MenuItem Header="_Файл">
                <MenuItem Header="Новое мероприятие (Ctrl+N)" Command="{Binding CreateEventCommand}"/>
                <Separator/>
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Мероприятия">
                <MenuItem Header="Создать (Ctrl+N)"       Command="{Binding CreateEventCommand}"/>
                <MenuItem Header="Редактировать (Ctrl+E)" Command="{Binding EditEventCommand}"/>
                <MenuItem Header="Удалить (Ctrl+D)"       Command="{Binding DeleteEventCommand}"/>
                <Separator/>
                <MenuItem Header="Детали (Ctrl+I)"        Command="{Binding ShowEventDetailCommand}"/>
            </MenuItem>
            <MenuItem Header="_Участники">
                <MenuItem Header="Зарегистрироваться"     Command="{Binding RegisterParticipantCommand}"/>
                <MenuItem Header="Добавить (орг.)"        Command="{Binding AddParticipantCommand}"/>
                <MenuItem Header="Удалить (орг.)"         Command="{Binding DeleteParticipantCommand}"/>
            </MenuItem>
            <MenuItem Header="_Аккаунт">
                <MenuItem Header="Войти (Ctrl+L)"  Command="{Binding LoginCommand}"/>
                <MenuItem Header="Выйти"           Command="{Binding LogoutCommand}"/>
            </MenuItem>
            <MenuItem Header="_Помощь">
                <MenuItem Header="О программе"    Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ══ ТУЛБАР ══ -->
        <Border DockPanel.Dock="Top" Background="White"
                BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Tag="➕" Content="Создать"
                        Template="{StaticResource ToolbarBtnTpl}"
                        Command="{Binding CreateEventCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#1E293B"
                        Background="Transparent" BorderThickness="0"/>
                <Button Tag="✏️" Content="Редактировать"
                        Template="{StaticResource ToolbarBtnTpl}"
                        Command="{Binding EditEventCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#1E293B"
                        Background="Transparent" BorderThickness="0"/>
                <Button Tag="🗑️" Content="Удалить"
                        Template="{StaticResource ToolbarBtnTpl}"
                        Command="{Binding DeleteEventCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#DC2626"
                        Background="Transparent" BorderThickness="0"/>
                <Button Tag="🔍" Content="Детали"
                        Template="{StaticResource ToolbarBtnTpl}"
                        Command="{Binding ShowEventDetailCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#7C3AED"
                        Background="Transparent" BorderThickness="0"/>
                <Rectangle Width="1" Fill="#E2E8F0" Margin="6,3"/>
                <Button Tag="👤" Content="Записаться"
                        Template="{StaticResource ToolbarBtnTpl}"
                        Command="{Binding RegisterParticipantCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#16A34A"
                        Background="Transparent" BorderThickness="0"/>
                <Rectangle Width="1" Fill="#E2E8F0" Margin="6,3"/>
                <!-- Спиннер -->
                <Border Background="#DBEAFE" CornerRadius="5" Padding="8,4"
                        Visibility="{Binding IsRegistering, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="⏳ Отправка приглашения…"
                               FontFamily="Segoe UI" FontSize="12" Foreground="#1E3A8A"/>
                </Border>
                <Rectangle Width="1" Fill="#E2E8F0" Margin="6,3"/>
                <!-- Не вошли -->
                <Border Visibility="{Binding IsLoggedIn, Converter={StaticResource InvBoolToVis}}">
                    <Button Tag="🔐" Content="Войти"
                            Template="{StaticResource ToolbarBtnTpl}"
                            Command="{Binding LoginCommand}"
                            FontFamily="Segoe UI" FontSize="12" Foreground="#1D4ED8"
                            Background="Transparent" BorderThickness="0"/>
                </Border>
                <!-- Вошли -->
                <Border Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#D1FAE5" CornerRadius="5" Padding="10,4">
                            <TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#065F46">
                                <Run Text="👤 "/><Run Text="{Binding CurrentUser.DisplayName, Mode=OneWay}"/>
                                <Run Text="  ·  "/><Run Text="{Binding CurrentUser.RoleDisplay, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>
                        <Button Tag="🚪" Content="Выйти"
                                Template="{StaticResource ToolbarBtnTpl}"
                                Command="{Binding LogoutCommand}"
                                FontFamily="Segoe UI" FontSize="12" Foreground="#DC2626"
                                Background="Transparent" BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══ ЗАГОЛОВОК ══ -->
        <Border DockPanel.Dock="Top" Background="#1E40AF" Padding="22,13">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Организация мероприятий"
                               FontFamily="Segoe UI" FontSize="20" FontWeight="Light" Foreground="White"/>
                    <TextBlock Text="MVVM  •  EF Core SQLite  •  Named Pipes  •  MMF  •  Анимации"
                               FontFamily="Segoe UI" FontSize="11" Foreground="#BFDBFE" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" CornerRadius="8" Background="#1D4ED8" Padding="14,7">
                    <TextBlock FontFamily="Segoe UI" FontSize="13" Foreground="White" FontWeight="SemiBold">
                        <Run Text="Мероприятий: "/>
                        <Run Text="{Binding Events.Count, Mode=OneWay}"
                             FontWeight="Bold" Foreground="White" FontSize="16"/>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <!-- ══ СТАТУС-СТРОКА ══ -->
        <Border DockPanel.Dock="Bottom" Background="White"
                BorderThickness="0,1,0,0" BorderBrush="#E2E8F0" Padding="14,6">
            <TextBlock Text="{Binding StatusMessage}"
                       FontFamily="Segoe UI" FontSize="12" Foreground="#475569"/>
        </Border>

        <!-- ══ РАБОЧАЯ ОБЛАСТЬ ══ -->
        <Grid Margin="14,12,14,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="220"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="270" MinWidth="210"/>
            </Grid.ColumnDefinitions>

            <!-- ── КОЛОНКА 1: ListView мероприятий ── -->
            <Border Grid.Column="0" Background="White" CornerRadius="12"
                    Effect="{StaticResource CardShadow}"
                    Style="{StaticResource AnimCard}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#1E40AF"
                            CornerRadius="12,12,0,0" Padding="14,11">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📋 Мероприятия" FontFamily="Segoe UI"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="+ Создать"
                                    Command="{Binding CreateEventCommand}"
                                    Template="{StaticResource SmallBtnTpl}"
                                    Background="White" Foreground="#1E40AF"
                                    FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                    Padding="9,4" BorderThickness="0"/>
                        </Grid>
                    </Border>

                    <!-- ★ ListView ItemsSource="{Binding Events}" ★ -->
                    <ListView ItemsSource="{Binding Events}"
                              SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                              ItemTemplate="{StaticResource EventListItemTpl}"
                              ItemContainerStyle="{StaticResource LvItemStyle}"
                              Background="Transparent" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick"
                                          Command="{Binding ShowEventDetailCommand}"/>
                        </ListView.InputBindings>
                    </ListView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- ── КОЛОНКА 2: Детали + Участники + Чат ── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="185"/>
                </Grid.RowDefinitions>

                <!-- Заглушка -->
                <Border Grid.Row="0" Grid.RowSpan="3" Background="White" CornerRadius="12"
                        Effect="{StaticResource CardShadow}"
                        Style="{StaticResource AnimCard1}"
                        Visibility="{Binding SelectedEvent,
                            Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="52" HorizontalAlignment="Center"/>
                        <TextBlock Text="Выберите мероприятие из списка" Margin="0,14,0,4"
                                   FontFamily="Segoe UI" FontSize="14" Foreground="#94A3B8"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Двойной клик → детали  •  Ctrl+N → создать"
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#CBD5E1"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Карточка мероприятия -->
                <Border Grid.Row="0" Background="White" CornerRadius="12"
                        Effect="{StaticResource CardShadow}"
                        Style="{StaticResource AnimCard1}"
                        Visibility="{Binding SelectedEvent, Converter={StaticResource NullToVis}}">
                    <Grid Margin="20,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <!-- TwoWay: название -->
                            <TextBox Text="{Binding SelectedEvent.Name, Mode=TwoWay,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Segoe UI" FontSize="19" FontWeight="SemiBold"
                                     Foreground="#0F172A" BorderThickness="0"
                                     Background="Transparent" Padding="0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="📅 " FontSize="12" VerticalAlignment="Center"/>
                                <!-- TwoWay: дата -->
                                <DatePicker SelectedDate="{Binding SelectedEvent.Date, Mode=TwoWay}"
                                            FontFamily="Segoe UI" FontSize="12"
                                            BorderThickness="0" Background="Transparent"
                                            Margin="0,-3,0,0" VerticalAlignment="Center"/>
                                <TextBlock Text="  📍 " FontSize="12" Foreground="#94A3B8"
                                           VerticalAlignment="Center"/>
                                <!-- TwoWay: место -->
                                <TextBox Text="{Binding SelectedEvent.Location, Mode=TwoWay,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Segoe UI" FontSize="12" Foreground="#64748B"
                                         BorderThickness="0" Background="Transparent" Padding="0"
                                         VerticalAlignment="Center" MinWidth="80"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- OneWay: счётчик -->
                            <Border CornerRadius="10" Background="#DBEAFE" Padding="12,7" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedEvent.ParticipantCount, Mode=OneWay}"
                                               FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                               Foreground="#1E3A8A" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedEvent.ParticipantCount, Mode=OneWay,
                                                   Converter={StaticResource CountToStr}}"
                                               FontFamily="Segoe UI" FontSize="10" Foreground="#1D4ED8"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Margin="0,0,8,0">
                                <Button Content="✏️ Ред."
                                        Command="{Binding EditEventCommand}"
                                        Template="{StaticResource SmallBtnTpl}"
                                        FontFamily="Segoe UI" FontSize="11"
                                        Padding="9,5" Margin="0,0,0,4"
                                        Background="#F1F5F9" Foreground="#334155" BorderThickness="0"/>
                                <Button Content="🗑️ Удал."
                                        Command="{Binding DeleteEventCommand}"
                                        Template="{StaticResource SmallBtnTpl}"
                                        FontFamily="Segoe UI" FontSize="11"
                                        Padding="9,5" Background="#FEF2F2"
                                        Foreground="#DC2626" BorderThickness="0"/>
                            </StackPanel>
                            <StackPanel>
                                <Button Content="🔍 Детали"
                                        Command="{Binding ShowEventDetailCommand}"
                                        Template="{StaticResource SmallBtnTpl}"
                                        FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                        Padding="10,5" Margin="0,0,0,4"
                                        Background="#F3E8FF" Foreground="#7C3AED" BorderThickness="0"/>
                                <!-- Кнопка с ControlTemplate (иконка человека) -->
                                <Button Content="Записаться"
                                        Template="{StaticResource RegisterBtnTpl}"
                                        Command="{Binding RegisterParticipantCommand}"
                                        FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                        Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Участники — ListBox -->
                <Border Grid.Row="2" Background="White" CornerRadius="12"
                        Effect="{StaticResource CardShadow}"
                        Style="{StaticResource AnimCard2}"
                        Visibility="{Binding SelectedEvent, Converter={StaticResource NullToVis}}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#16A34A"
                                CornerRadius="12,12,0,0" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👥 Участники" FontFamily="Segoe UI"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                    <Border CornerRadius="10" Background="#FFFFFF30"
                                            Padding="8,2" Margin="8,0,0,0">
                                        <!-- OneWay: счётчик в заголовке -->
                                        <TextBlock Text="{Binding SelectedEvent.ParticipantCount, Mode=OneWay}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            Visibility="{Binding IsOrganizer, Converter={StaticResource BoolToVis}}">
                                    <Button Content="+ Добавить"
                                            Command="{Binding AddParticipantCommand}"
                                            Template="{StaticResource SmallBtnTpl}"
                                            Background="White" Foreground="#16A34A"
                                            FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                            Padding="8,4" BorderThickness="0" Margin="0,0,5,0"/>
                                    <Button Content="✏️"
                                            Command="{Binding EditParticipantCommand}"
                                            Template="{StaticResource SmallBtnTpl}"
                                            Padding="7,4" Background="#FFFFFF30"
                                            Foreground="White" BorderThickness="0" Margin="0,0,4,0"/>
                                    <Button Content="🗑️"
                                            Command="{Binding DeleteParticipantCommand}"
                                            Template="{StaticResource SmallBtnTpl}"
                                            Padding="7,4" Background="#FEE2E2"
                                            Foreground="#DC2626" BorderThickness="0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ★ ListBox Participants ★ -->
                        <ListBox ItemsSource="{Binding CurrentParticipants}"
                                 SelectedItem="{Binding SelectedParticipant, Mode=TwoWay}"
                                 ItemTemplate="{StaticResource ParticipantItemTpl}"
                                 ItemContainerStyle="{StaticResource LbItemStyle}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Border>

                <!-- Чат -->
                <Border Grid.Row="4" Background="White" CornerRadius="12"
                        Effect="{StaticResource CardShadow}"
                        Style="{StaticResource AnimCard3}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#1E40AF"
                                CornerRadius="12,12,0,0" Padding="12,9">
                            <TextBlock Text="💬 Обсуждение (Named Pipes)"
                                       FontFamily="Segoe UI" FontSize="12"
                                       FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <Grid DockPanel.Dock="Bottom" Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ChatInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Segoe UI" FontSize="12"
                                     Background="#F8FAFC" Foreground="#1E293B"
                                     BorderBrush="#E2E8F0" Padding="8,7">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SendChatCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="2" Content="▶"
                                    Command="{Binding SendChatCommand}"
                                    Template="{StaticResource SmallBtnTpl}"
                                    Background="#1E40AF" Foreground="White"
                                    FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                                    Padding="14,7" BorderThickness="0"/>
                        </Grid>
                        <ListBox ItemsSource="{Binding ChatMessages}"
                                 Background="Transparent" BorderThickness="0"
                                 FontFamily="Segoe UI" FontSize="12" Foreground="#1E293B"
                                 Padding="8,4"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- ── КОЛОНКА 3: Календарь + Уведомления + Лог ── -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Календарь -->
                <Border Grid.Row="0" Background="White" CornerRadius="12"
                        Effect="{StaticResource CardShadow}"
                        Style="{StaticResource AnimCard1}">
                    <StackPanel>
                        <Border Background="#7C3AED" CornerRadius="12,12,0,0" Padding="12,10">
                            <TextBlock Text="📆 Календарь мероприятий"
                                       FontFamily="Segoe UI" FontSize="12"
                                       FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <Calendar SelectedDate="{Binding SelectedCalendarDate, Mode=TwoWay}"
                                  DisplayMode="Month" HorizontalAlignment="Stretch"
                                  FontFamily="Segoe UI" FontSize="12" Margin="4">
                            <Calendar.Resources>
                                <!-- Кнопки дней -->
                                <Style TargetType="CalendarDayButton">
                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="MinWidth" Value="30"/>
                                    <Setter Property="MinHeight" Value="30"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#DBEAFE"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1E40AF"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsToday" Value="True">
                                            <Setter Property="Background" Value="#EFF6FF"/>
                                            <Setter Property="Foreground" Value="#1D4ED8"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Trigger>
                                        <Trigger Property="IsInactive" Value="True">
                                            <Setter Property="Foreground" Value="#CBD5E1"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <!-- Кнопки месяцев/годов -->
                                <Style TargetType="CalendarButton">
                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Setter Property="Background" Value="White"/>
                                </Style>
                            </Calendar.Resources>
                        </Calendar>
                        <!-- События выбранного дня -->
                        <Border Background="#F5F3FF" Padding="10,8" CornerRadius="0,0,12,12"
                                Visibility="{Binding CalendarDayEvents.Count, Converter={StaticResource NullToVis}}">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe UI" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#7C3AED" Margin="0,0,0,5">
                                    <Run Text="События на "/>
                                    <Run Text="{Binding SelectedCalendarDate, StringFormat='dd.MM.yyyy', Mode=OneWay}"/>
                                    <Run Text=":"/>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding CalendarDayEvents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="5"
                                                    Padding="8,4" Margin="0,2"
                                                    BorderBrush="#DDD6FE" BorderThickness="1">
                                                <TextBlock Text="{Binding Name}"
                                                           FontFamily="Segoe UI" FontSize="11"
                                                           Foreground="#1E293B"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Уведомления MMF -->
                <Border Grid.Row="2" Background="White" CornerRadius="12"
                        Effect="{StaticResource CardShadow}"
                        Style="{StaticResource AnimCard2}">
                    <StackPanel>
                        <Border Background="#D97706" CornerRadius="12,12,0,0" Padding="12,10">
                            <TextBlock Text="🔔 Уведомления расписания (MMF)"
                                       FontFamily="Segoe UI" FontSize="12"
                                       FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <TextBlock Text="Нет уведомлений"
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#94A3B8"
                                   Margin="12,10" HorizontalAlignment="Center"
                                   Visibility="{Binding Notifications.Count,
                                       Converter={StaticResource NullToVis}, ConverterParameter=Invert}"/>
                        <ListBox ItemsSource="{Binding Notifications}"
                                 Background="Transparent" BorderThickness="0"
                                 FontFamily="Segoe UI" FontSize="12" Foreground="#451A03"
                                 MaxHeight="90" Padding="10,6"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Border>

                <!-- Лог -->
                <Border Grid.Row="4" Background="White" CornerRadius="12"
                        Effect="{StaticResource CardShadow}"
                        Style="{StaticResource AnimCard3}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#475569"
                                CornerRadius="12,12,0,0" Padding="12,10">
                            <TextBlock Text="📋 Лог изменений"
                                       FontFamily="Segoe UI" FontSize="12"
                                       FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                        <ListBox ItemsSource="{Binding Notifications}"
                                 Background="Transparent" BorderThickness="0"
                                 FontFamily="Segoe UI" FontSize="12" Foreground="#1E293B"
                                 Padding="10,6"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
