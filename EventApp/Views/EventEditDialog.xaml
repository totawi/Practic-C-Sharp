<Window x:Class="EventApp.Views.EventEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мероприятие" Height="380" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <ControlTemplate x:Key="DialogBtnTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="5" Padding="{TemplateBinding Padding}" Cursor="Hand">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Border Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Label Content="Название мероприятия *"/>
                <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Дата *"/>
                <DatePicker SelectedDate="{Binding Date, Mode=TwoWay}"/>

                <Label Content="Место проведения"/>
                <TextBox Text="{Binding Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Секция / Направление"/>
                <TextBox Text="{Binding Section, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Описание"/>
                <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="BtnCancel" Content="Отмена"
                        Template="{StaticResource DialogBtnTemplate}"
                        Background="#EDF2F7" Foreground="#4A5568"
                        FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="22,8" Margin="0,0,10,0" BorderThickness="0"
                        Click="BtnCancel_Click"/>
                <Button x:Name="BtnOk" Content="Сохранить"
                        Template="{StaticResource DialogBtnTemplate}"
                        Background="#2B6CB0" Foreground="White"
                        FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                        Padding="22,8" BorderThickness="0"
                        Click="BtnOk_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
