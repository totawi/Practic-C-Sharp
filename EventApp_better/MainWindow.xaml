<Window x:Class="EventApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:EventApp.Converters"
        Title="Организация мероприятий" Height="740" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7"
        Closing="Window_Closing">

    <Window.Resources>
        <conv:BoolToVisibilityConverter  x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter  x:Key="NullToVis"/>
        <conv:CountToStringConverter     x:Key="CountToStr"/>
        <conv:InverseBoolToVisConverter  x:Key="InvBoolToVis"/>

        <DropShadowEffect x:Key="CardShadow" Color="#CBD5E0"
                          BlurRadius="10" ShadowDepth="2" Opacity="0.35"/>

        <!-- ControlTemplate: зелёная кнопка «Зарегистрироваться» с иконкой -->
        <ControlTemplate x:Key="RegisterBtnTpl" TargetType="Button">
            <Border x:Name="Bd" Background="#276749" CornerRadius="6"
                    Padding="14,8" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="16" Height="16" Margin="0,0,7,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White" Data="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4
                                12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6
                                4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                        </Canvas>
                    </Viewbox>
                    <ContentPresenter VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#22543D"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Background" Value="#A0AEC0"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ControlTemplate: кнопки панели инструментов -->
        <ControlTemplate x:Key="ToolbarBtnTpl" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="5" Padding="10,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{TemplateBinding Tag}" FontSize="14"
                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <ContentPresenter VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#E2E8F0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ControlTemplate: маленькая кнопка -->
        <ControlTemplate x:Key="SmallBtnTpl" TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="5" Padding="{TemplateBinding Padding}" Cursor="Hand">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- DataTemplate: карточка мероприятия в ListBox -->
        <DataTemplate x:Key="EventItemTemplate">
            <Border x:Name="ItemBorder" Background="White"
                    BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Name}"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#1A202C" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock Text="📅 " FontSize="11"/>
                            <TextBlock Text="{Binding DateDisplay}"
                                       FontFamily="Segoe UI" FontSize="11" Foreground="#718096"/>
                            <TextBlock Text="  •  📍 " FontSize="11" Foreground="#A0AEC0"/>
                            <TextBlock Text="{Binding Location}"
                                       FontFamily="Segoe UI" FontSize="11" Foreground="#718096"
                                       TextTrimming="CharacterEllipsis" MaxWidth="100"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="10" Padding="8,3"
                            Background="#EBF4FF" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥 " FontSize="10"/>
                            <TextBlock Text="{Binding ParticipantCount, Mode=OneWay}"
                                       FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                                       Foreground="#2B6CB0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected,
                    RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="#EBF4FF"/>
                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#BEE3F8"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- DataTemplate: строка участника -->
        <DataTemplate x:Key="ParticipantItemTemplate">
            <Border x:Name="PBorder" Background="Transparent"
                    BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                            Background="#2B6CB0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LastName[0]}"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FullName}"
                                   FontFamily="Segoe UI" FontSize="13" Foreground="#1A202C"/>
                        <TextBlock Text="{Binding Email}"
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#718096"/>
                    </StackPanel>
                    <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                            Background="#F0FFF4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Section}"
                                   FontFamily="Segoe UI" FontSize="10" Foreground="#276749"/>
                    </Border>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected,
                    RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="PBorder" Property="Background" Value="#EBF8FF"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="CleanListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style x:Key="CleanItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Горячие клавиши -->
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding CreateEventCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditEventCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteEventCommand}"/>
        <KeyBinding Key="L" Modifiers="Ctrl" Command="{Binding LoginCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ГЛАВНОЕ МЕНЮ -->
        <Menu DockPanel.Dock="Top" Background="#2D3748" FontFamily="Segoe UI" FontSize="13">
            <Menu.ItemContainerStyle>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="#4A5568"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Menu.ItemContainerStyle>
            <MenuItem Header="_Файл">
                <MenuItem Header="Новое мероприятие (Ctrl+N)" Command="{Binding CreateEventCommand}"/>
                <Separator/>
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Мероприятия">
                <MenuItem Header="Создать (Ctrl+N)"       Command="{Binding CreateEventCommand}"/>
                <MenuItem Header="Редактировать (Ctrl+E)" Command="{Binding EditEventCommand}"/>
                <MenuItem Header="Удалить (Ctrl+D)"       Command="{Binding DeleteEventCommand}"/>
            </MenuItem>
            <MenuItem Header="_Участники">
                <MenuItem Header="Зарегистрироваться на мероприятие" Command="{Binding RegisterParticipantCommand}"/>
                <Separator/>
                <MenuItem Header="Добавить вручную (орг.)"   Command="{Binding AddParticipantCommand}"/>
                <MenuItem Header="Редактировать (орг.)"      Command="{Binding EditParticipantCommand}"/>
                <MenuItem Header="Удалить участника (орг.)"  Command="{Binding DeleteParticipantCommand}"/>
            </MenuItem>
            <MenuItem Header="_Аккаунт">
                <MenuItem Header="Войти (Ctrl+L)"  Command="{Binding LoginCommand}"/>
                <MenuItem Header="Выйти"           Command="{Binding LogoutCommand}"/>
            </MenuItem>
            <MenuItem Header="_Помощь">
                <MenuItem Header="О программе" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ПАНЕЛЬ ИНСТРУМЕНТОВ -->
        <Border DockPanel.Dock="Top" Background="#F7FAFC"
                BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Tag="➕" Content="Создать"
                        Template="{StaticResource ToolbarBtnTpl}"
                        Command="{Binding CreateEventCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#2D3748"
                        Background="Transparent" BorderThickness="0"/>
                <Button Tag="✏️" Content="Редактировать"
                        Template="{StaticResource ToolbarBtnTpl}"
                        Command="{Binding EditEventCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#2D3748"
                        Background="Transparent" BorderThickness="0"/>
                <Button Tag="🗑️" Content="Удалить"
                        Template="{StaticResource ToolbarBtnTpl}"
                        Command="{Binding DeleteEventCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#C53030"
                        Background="Transparent" BorderThickness="0"/>
                <Rectangle Width="1" Fill="#CBD5E0" Margin="6,4"/>
                <Button Tag="👤" Content="Зарегистрироваться"
                        Template="{StaticResource ToolbarBtnTpl}"
                        Command="{Binding RegisterParticipantCommand}"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#276749"
                        Background="Transparent" BorderThickness="0"/>
                <Rectangle Width="1" Fill="#CBD5E0" Margin="6,4"/>
                <!-- Спиннер загрузки -->
                <Border Background="#EBF4FF" CornerRadius="4" Padding="8,4"
                        Visibility="{Binding IsRegistering, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="⏳ Отправка приглашения…"
                               FontFamily="Segoe UI" FontSize="12" Foreground="#2B6CB0"/>
                </Border>
                <Rectangle Width="1" Fill="#CBD5E0" Margin="6,4"/>
                <!-- Auth блок -->
                <Border Visibility="{Binding IsLoggedIn, Converter={StaticResource InvBoolToVis}}">
                    <Button Tag="🔐" Content="Войти"
                            Template="{StaticResource ToolbarBtnTpl}"
                            Command="{Binding LoginCommand}"
                            FontFamily="Segoe UI" FontSize="12" Foreground="#2B6CB0"
                            Background="Transparent" BorderThickness="0"/>
                </Border>
                <Border Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#F0FFF4" CornerRadius="4" Padding="8,4">
                            <TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#276749">
                                <Run Text="👤 "/>
                                <Run Text="{Binding CurrentUser.DisplayName, Mode=OneWay}"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding CurrentUser.RoleDisplay, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </Border>
                        <Button Tag="🚪" Content="Выйти"
                                Template="{StaticResource ToolbarBtnTpl}"
                                Command="{Binding LogoutCommand}"
                                FontFamily="Segoe UI" FontSize="12" Foreground="#C53030"
                                Background="Transparent" BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ЗАГОЛОВОК -->
        <Border DockPanel.Dock="Top" Background="#2B6CB0" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Организация мероприятий"
                               FontFamily="Segoe UI" FontSize="20" FontWeight="Light" Foreground="White"/>
                    <TextBlock Text="MVVM • Named Pipes • MMF • JSON Storage • Async"
                               FontFamily="Segoe UI" FontSize="11" Foreground="#BEE3F8" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" CornerRadius="8" Background="#2C5282" Padding="12,6">
                    <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#90CDF4">
                        <Run Text="Мероприятий: "/>
                        <Run Text="{Binding Events.Count, Mode=OneWay}"
                             FontWeight="Bold" Foreground="White"/>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <!-- СТАТУСНАЯ СТРОКА (снизу) -->
        <Border DockPanel.Dock="Bottom" Background="#2D3748" Padding="12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#E2E8F0"/>

            </Grid>
        </Border>

        <!-- РАБОЧАЯ ОБЛАСТЬ — три колонки -->
        <Grid Margin="12,10,12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" MinWidth="220"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="260" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- ══════ КОЛОНКА 1: Список мероприятий ══════ -->
            <Border Grid.Column="0" Background="White" CornerRadius="10"
                    Effect="{StaticResource CardShadow}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#EBF4FF"
                            CornerRadius="10,10,0,0" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Мероприятия"
                                       FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#2B6CB0" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="+ Создать"
                                    Command="{Binding CreateEventCommand}"
                                    Template="{StaticResource SmallBtnTpl}"
                                    Background="#2B6CB0" Foreground="White"
                                    FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                    Padding="8,4" BorderThickness="0"/>
                        </Grid>
                    </Border>
                    <ListBox Style="{StaticResource CleanListBoxStyle}"
                             ItemContainerStyle="{StaticResource CleanItemStyle}"
                             ItemsSource="{Binding Events}"
                             SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                             ItemTemplate="{StaticResource EventItemTemplate}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- ══════ КОЛОНКА 2: Детали + Участники + Чат ══════ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>

                <!-- Заглушка когда ничего не выбрано -->
                <Border Grid.Row="0" Grid.RowSpan="3"
                        Background="White" CornerRadius="10"
                        Effect="{StaticResource CardShadow}"
                        Visibility="{Binding SelectedEvent,
                            Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="Выберите мероприятие" Margin="0,12,0,4"
                                   FontFamily="Segoe UI" FontSize="15" Foreground="#A0AEC0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="или создайте новое (Ctrl+N)"
                                   FontFamily="Segoe UI" FontSize="12" Foreground="#CBD5E0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Карточка мероприятия (TwoWay binding) -->
                <Border Grid.Row="0" Background="White" CornerRadius="10"
                        Effect="{StaticResource CardShadow}"
                        Visibility="{Binding SelectedEvent, Converter={StaticResource NullToVis}}">
                    <Grid Margin="18,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <!-- TwoWay: название -->
                            <TextBox Text="{Binding SelectedEvent.Name,
                                         Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold"
                                     Foreground="#1A202C" BorderThickness="0"
                                     Background="Transparent" Padding="0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="📅 " FontSize="12" VerticalAlignment="Center"/>
                                <!-- TwoWay: дата -->
                                <DatePicker SelectedDate="{Binding SelectedEvent.Date, Mode=TwoWay}"
                                            FontFamily="Segoe UI" FontSize="12"
                                            BorderThickness="0" Background="Transparent"
                                            Margin="0,-3,0,0" VerticalAlignment="Center"/>
                                <TextBlock Text="  📍 " FontSize="12" Foreground="#A0AEC0"
                                           VerticalAlignment="Center"/>
                                <!-- TwoWay: место -->
                                <TextBox Text="{Binding SelectedEvent.Location,
                                             Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="Segoe UI" FontSize="12" Foreground="#718096"
                                         BorderThickness="0" Background="Transparent" Padding="0"
                                         VerticalAlignment="Center" MinWidth="80"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- OneWay: счётчик участников -->
                            <Border CornerRadius="8" Background="#EBF4FF"
                                    Padding="10,5" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedEvent.ParticipantCount, Mode=OneWay}"
                                               FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                                               Foreground="#2B6CB0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedEvent.ParticipantCount,
                                                   Mode=OneWay, Converter={StaticResource CountToStr}}"
                                               FontFamily="Segoe UI" FontSize="10" Foreground="#718096"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Margin="0,0,8,0">
                                <Button Content="✏️ Ред."
                                        Command="{Binding EditEventCommand}"
                                        Template="{StaticResource SmallBtnTpl}"
                                        FontFamily="Segoe UI" FontSize="11"
                                        Padding="8,5" Margin="0,0,0,3"
                                        Background="#EDF2F7" Foreground="#2D3748" BorderThickness="0"/>
                                <Button Content="🗑️ Удал."
                                        Command="{Binding DeleteEventCommand}"
                                        Template="{StaticResource SmallBtnTpl}"
                                        FontFamily="Segoe UI" FontSize="11"
                                        Padding="8,5" Background="#FFF5F5"
                                        Foreground="#C53030" BorderThickness="0"/>
                            </StackPanel>
                            <!-- Кнопка регистрации (ControlTemplate с иконкой человека) -->
                            <Button Content="Записаться"
                                    Template="{StaticResource RegisterBtnTpl}"
                                    Command="{Binding RegisterParticipantCommand}"
                                    FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                    Foreground="White" BorderThickness="0"
                                    ToolTip="Зарегистрироваться на мероприятие"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Панель участников -->
                <Border Grid.Row="2" Background="White" CornerRadius="10"
                        Effect="{StaticResource CardShadow}"
                        Visibility="{Binding SelectedEvent, Converter={StaticResource NullToVis}}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#F0FFF4"
                                CornerRadius="10,10,0,0" Padding="14,9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Участники"
                                               FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#276749" VerticalAlignment="Center"/>
                                    <Border CornerRadius="10" Background="#276749" Padding="7,2" Margin="7,0,0,0">
                                        <TextBlock Text="{Binding SelectedEvent.ParticipantCount, Mode=OneWay}"
                                                   FontFamily="Segoe UI" FontSize="10"
                                                   FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            Visibility="{Binding IsOrganizer, Converter={StaticResource BoolToVis}}">
                                    <Button Content="+ Добавить"
                                            Command="{Binding AddParticipantCommand}"
                                            Template="{StaticResource SmallBtnTpl}"
                                            Background="#276749" Foreground="White"
                                            FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                            Padding="8,4" BorderThickness="0" Margin="0,0,6,0"/>
                                    <Button Content="✏️"
                                            Command="{Binding EditParticipantCommand}"
                                            Template="{StaticResource SmallBtnTpl}"
                                            Padding="7,4" Background="#EDF2F7"
                                            Foreground="#2D3748" BorderThickness="0" Margin="0,0,4,0"/>
                                    <Button Content="🗑️"
                                            Command="{Binding DeleteParticipantCommand}"
                                            Template="{StaticResource SmallBtnTpl}"
                                            Padding="7,4" Background="#FFF5F5"
                                            Foreground="#C53030" BorderThickness="0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ListBox Style="{StaticResource CleanListBoxStyle}"
                                 ItemContainerStyle="{StaticResource CleanItemStyle}"
                                 ItemsSource="{Binding CurrentParticipants}"
                                 SelectedItem="{Binding SelectedParticipant, Mode=TwoWay}"
                                 ItemTemplate="{StaticResource ParticipantItemTemplate}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Border>

                <!-- ЧАТ (Named Pipes) -->
                <Border Grid.Row="4" Background="White" CornerRadius="10"
                        Effect="{StaticResource CardShadow}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#EBF8FF"
                                CornerRadius="10,10,0,0" Padding="12,8">
                            <TextBlock Text="💬 Обсуждение (Named Pipes)"
                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#2B6CB0"/>
                        </Border>
                        <!-- Ввод -->
                        <Grid DockPanel.Dock="Bottom" Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ChatInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Segoe UI" FontSize="12"
                                     Padding="8,6" BorderBrush="#CBD5E0">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SendChatCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="2" Content="▶ Отправить"
                                    Command="{Binding SendChatCommand}"
                                    Template="{StaticResource SmallBtnTpl}"
                                    Background="#2B6CB0" Foreground="White"
                                    FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                    Padding="10,6" BorderThickness="0"/>
                        </Grid>
                        <!-- Сообщения -->
                        <ListBox ItemsSource="{Binding ChatMessages}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 FontFamily="Segoe UI" FontSize="11"
                                 Foreground="#2D3748" Padding="8,4"/>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- ══════ КОЛОНКА 3: Календарь + Уведомления ══════ -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- CALENDAR VIEW -->
                <Border Grid.Row="0" Background="White" CornerRadius="10"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <Border Background="#553C9A" CornerRadius="10,10,0,0" Padding="12,9">
                            <TextBlock Text="📆 Календарь мероприятий"
                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>
                        <Calendar x:Name="EventCalendar"
                                  SelectedDate="{Binding SelectedCalendarDate, Mode=TwoWay}"
                                  DisplayMode="Month"
                                  HorizontalAlignment="Stretch"
                                  FontFamily="Segoe UI" FontSize="12"
                                  Margin="4"/>
                        <!-- События выбранного дня -->
                        <Border Background="#FAF5FF" Padding="10,8"
                                CornerRadius="0,0,10,10"
                                Visibility="{Binding CalendarDayEvents.Count,
                                    Converter={StaticResource NullToVis}}">
                            <StackPanel>
                                <TextBlock FontFamily="Segoe UI" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#553C9A"
                                           Margin="0,0,0,6">
                                    <Run Text="События на "/>
                                    <Run Text="{Binding SelectedCalendarDate, StringFormat='dd.MM.yyyy', Mode=OneWay}"/>
                                    <Run Text=":"/>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding CalendarDayEvents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="4"
                                                    Padding="6,4" Margin="0,2">
                                                <TextBlock Text="{Binding Name}"
                                                           FontFamily="Segoe UI" FontSize="11"
                                                           Foreground="#2D3748" TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- УВЕДОМЛЕНИЯ (MMF) -->
                <Border Grid.Row="2" Background="White" CornerRadius="10"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <Border Background="#744210" CornerRadius="10,10,0,0" Padding="12,9">
                            <TextBlock Text="🔔 Уведомления расписания (MMF)"
                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>
                        <TextBlock Text="Нет уведомлений"
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#A0AEC0"
                                   Margin="12,10" HorizontalAlignment="Center"
                                   Visibility="{Binding Notifications.Count,
                                       Converter={StaticResource NullToVis}, ConverterParameter=Invert}"/>
                        <ListBox ItemsSource="{Binding Notifications}"
                                 Background="Transparent" BorderThickness="0"
                                 FontFamily="Segoe UI" FontSize="11" Foreground="#2D3748"
                                 MaxHeight="100" Padding="8,4"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Border>

                <!-- ПОСЛЕДНИЕ ДЕЙСТВИЯ / лог -->
                <Border Grid.Row="4" Background="White" CornerRadius="10"
                        Effect="{StaticResource CardShadow}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#2D3748"
                                CornerRadius="10,10,0,0" Padding="12,9">
                            <TextBlock Text="📋 Лог событий"
                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>
                        <ListBox ItemsSource="{Binding Notifications}"
                                 Background="Transparent" BorderThickness="0"
                                 FontFamily="Segoe UI" FontSize="11" Foreground="#4A5568"
                                 Padding="8,4"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
